{
  "name": "receiptbot",
  "version": "0.1.0",
  "private": true,
  "description": "Runtime governance + auditing tool for AI agents",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter @receiptbot/viewer dev",
    "viewer:dev": "pnpm --filter @receiptbot/viewer dev",
    "viewer:build": "pnpm --filter @receiptbot/viewer build",
    "demo:rogue": "tsx examples/rogue-dev.ts",
    "example:rogue": "tsx examples/rogue-dev.ts",
    "example:wallet": "tsx examples/wallet-drainer.ts",
    "clean": "pnpm -r exec rimraf dist"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "rimraf": "^5.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
